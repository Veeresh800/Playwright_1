{
  "name": "playwright-cucumber-ts",
  "version": "1.0.0",
  "description": "Playwright Cucumber TypeScript Framework",
  "scripts": {
    "test": "cucumber-js",
    "test:chrome": "cucumber-js --profile chrome && npm run generate:report",
    "test:firefox": "cucumber-js --profile firefox",
    "test:webkit": "cucumber-js --profile webkit",
    "test:msedge": "cucumber-js --profile msedge",
    "report": "node utils/generate-html-report.js",
    "test:report": "npm test && npm run report",
    "generate:report": "npx ts-node ./utils/ReportGenerate.ts",
    "upload:specs": "npx ts-node ./Jira_Connector/upload-specs-to-jira.ts",
    "pw:test": "playwright test",
    "pw:test:allure": "playwright test --reporter=allure-playwright --reporter=list && npm run allure:generate",
    "pw:test:ui": "playwright test --ui",
    "pw:test:debug": "playwright test --debug",
    "pw:test:air6": "playwright test tests/AIR-6/flight-search.spec.ts",
    "pw:test:air6:allure": "playwright test tests/AIR-6/flight-search.spec.ts --reporter=allure-playwright --reporter=list && npm run allure:generate",
    "allure:report": "npm run allure:generate && npx allure open reports/allure-report",
    "allure:generate": "npx allure generate reports/allure-results --clean -o reports/allure-report",
    "allure:open": "npx allure open reports/allure-report"
  },
  "dependencies": {
    "@cucumber/messages": "^21.0.0",
    "@playwright/test": "^1.30.0",
    "allure-cucumberjs": "^2.9.2",
    "axios": "^1.17.0",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.0.3",
    "exceljs": "^4.3.0",
    "form-data": "^4.0.5",
    "fs-extra": "^11.1.0",
    "multiple-cucumber-html-reporter": "^3.4.0",
    "typescript": "^4.9.5",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@types/chai": "^4.3.4",
    "@types/fs-extra": "^11.0.1",
    "@types/node": "^18.13.0",
    "allure-commandline": "^2.20.1",
    "allure-playwright": "^3.9.0",
    "chai": "^4.3.7",
    "cucumber-html-reporter": "^6.0.0",
    "cucumberjs-allure2-reporter": "^1.3.0",
    "ts-node": "^10.9.1"
  }
}
